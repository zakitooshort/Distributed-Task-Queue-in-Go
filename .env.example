# postgres connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=taskqueue
DB_PASSWORD=taskqueue
DB_NAME=taskqueue

# redis
REDIS_URL=redis://localhost:6379

# server
PORT=8080

# worker settings (can override per instance)
WORKER_QUEUES=default,critical,email
WORKER_CONCURRENCY=5

# how long before a "running" job is considered stuck (minutes)
STUCK_JOB_TIMEOUT_MINUTES=5
